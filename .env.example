# Local environment (copy to `.env.local`)

# SQLite locally — leave as-is for development
DATABASE_URL=file:./db.sqlite

# Required in production (min 16 random characters)
SESSION_SECRET=change-me-to-a-long-random-string

# Public URL for customer tracking links (no login required)
# Example: https://pawps-ph-montalban.vercel.app
NEXT_PUBLIC_SITE_URL=https://pawps-ph-montalban.vercel.app

# First admin (created only when users table is empty)
ADMIN_EMAIL=xjaequeral@gmail.com
ADMIN_PASSWORD=092925

# Anthropic Claude — OPTIONAL. Only needed for scanning pricelist photos with AI.
# Free mode works for pasted text and text-based PDFs without this key.
# ANTHROPIC_API_KEY=sk-ant-...

# Turso (production — set in Vercel, not in committed files)
# DATABASE_URL=libsql://your-database.turso.io
# DATABASE_AUTH_TOKEN=paste-from-turso-dashboard